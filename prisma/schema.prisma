// Prisma schema for SOE Engage — a gamified student engagement platform.
// Data source: PostgreSQL. Client: @prisma/client.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --------------------------------------------------------------------
// Auth + Identity
// --------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  passwordHash  String?
  emailVerified DateTime?

  // Gamification core
  xp            Int       @default(0)
  level         Int       @default(1)
  coins         Int       @default(0)
  streakCount   Int       @default(0)
  lastActiveDay DateTime?

  // Profile extras
  department    String?
  year          String?
  bio           String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  posts             Post[]
  comments          Comment[]
  postLikes         PostLike[]
  pollVotes         PollVote[]
  quizAttempts      QuizAttempt[]
  challengeProgress ChallengeProgress[]
  eventCheckins     EventCheckin[]
  earnedBadges      UserBadge[]
  xpEvents          XpEvent[]
  redemptions       RewardRedemption[]

  @@index([xp(sort: Desc)])
  @@index([level(sort: Desc)])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --------------------------------------------------------------------
// XP, Levels & Coins — every reward event is logged for transparency
// and for audit-able leaderboards.
// --------------------------------------------------------------------

enum XpSource {
  DAILY_LOGIN
  STREAK_BONUS
  CHALLENGE
  QUIZ
  POLL_VOTE
  EVENT_CHECKIN
  POST_CREATED
  POST_LIKED
  BADGE
  MANUAL
}

model XpEvent {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  coins     Int      @default(0)
  source    XpSource
  reason    String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([createdAt])
}

// --------------------------------------------------------------------
// Badges & Achievements
// --------------------------------------------------------------------

model Badge {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  emoji       String   @default("🏅")
  color       String   @default("#f59e0b")
  rarity      String   @default("common") // common, rare, epic, legendary
  xpReward    Int      @default(0)
  createdAt   DateTime @default(now())

  users UserBadge[]
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
}

// --------------------------------------------------------------------
// Daily / Weekly Challenges (Quests)
// --------------------------------------------------------------------

enum ChallengeType {
  DAILY
  WEEKLY
  SPECIAL
}

enum ChallengeStatus {
  IN_PROGRESS
  COMPLETED
  CLAIMED
}

model Challenge {
  id          String        @id @default(cuid())
  title       String
  description String
  type        ChallengeType @default(DAILY)
  emoji       String        @default("🎯")
  goal        Int           @default(1)
  xpReward    Int           @default(50)
  coinReward  Int           @default(10)
  activeFrom  DateTime      @default(now())
  activeUntil DateTime?
  createdAt   DateTime      @default(now())

  progress ChallengeProgress[]

  @@index([type, activeFrom])
}

model ChallengeProgress {
  id          String          @id @default(cuid())
  userId      String
  challengeId String
  progress    Int             @default(0)
  status      ChallengeStatus @default(IN_PROGRESS)
  completedAt DateTime?
  claimedAt   DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
  @@index([userId, status])
}

// --------------------------------------------------------------------
// Events & Check-ins (campus events + ICASS)
// --------------------------------------------------------------------

model CampusEvent {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?
  location    String?
  imageUrl    String?
  startsAt    DateTime
  endsAt      DateTime?
  xpReward    Int      @default(30)
  coinReward  Int      @default(5)
  checkinCode String?  @unique
  createdAt   DateTime @default(now())

  checkins EventCheckin[]

  @@index([startsAt])
}

model EventCheckin {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  createdAt DateTime @default(now())

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  event CampusEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([eventId])
}

// --------------------------------------------------------------------
// Social Feed — posts, likes, comments
// --------------------------------------------------------------------

model Post {
  id        String   @id @default(cuid())
  authorId  String
  content   String   @db.Text
  imageUrl  String?
  eventTag  String?
  createdAt DateTime @default(now())

  author   User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments Comment[]
  likes    PostLike[]

  @@index([createdAt(sort: Desc)])
  @@index([authorId])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId])
}

// --------------------------------------------------------------------
// Live Polls — instant feedback, live percentages
// --------------------------------------------------------------------

model Poll {
  id          String       @id @default(cuid())
  question    String
  description String?
  emoji       String       @default("💬")
  xpReward    Int          @default(10)
  closesAt    DateTime?
  createdAt   DateTime     @default(now())

  options PollOption[]
  votes   PollVote[]

  @@index([createdAt(sort: Desc)])
}

model PollOption {
  id     String @id @default(cuid())
  pollId String
  label  String
  emoji  String?
  order  Int    @default(0)

  poll  Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes PollVote[]
}

model PollVote {
  id        String   @id @default(cuid())
  pollId    String
  optionId  String
  userId    String
  createdAt DateTime @default(now())

  poll   Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId])
  @@index([pollId])
  @@index([optionId])
}

// --------------------------------------------------------------------
// Quizzes / Trivia — instant scoring, XP awarded on submit
// --------------------------------------------------------------------

model Quiz {
  id          String   @id @default(cuid())
  title       String
  description String?
  emoji       String   @default("🧠")
  xpPerQ      Int      @default(20)
  timeLimit   Int      @default(30) // seconds per question
  createdAt   DateTime @default(now())

  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@index([createdAt(sort: Desc)])
}

model QuizQuestion {
  id        String   @id @default(cuid())
  quizId    String
  prompt    String
  choices   String[] // array of choice strings
  answerIdx Int
  order     Int      @default(0)

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

model QuizAttempt {
  id           String   @id @default(cuid())
  userId       String
  quizId       String
  score        Int      @default(0)
  totalQs      Int      @default(0)
  xpEarned     Int      @default(0)
  completedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([quizId, score(sort: Desc)])
}

// --------------------------------------------------------------------
// Rewards Shop — redeem coins for perks
// --------------------------------------------------------------------

model Reward {
  id          String   @id @default(cuid())
  title       String
  description String
  emoji       String   @default("🎁")
  cost        Int      @default(100)
  stock       Int?     // null = unlimited
  imageUrl    String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  redemptions RewardRedemption[]
}

model RewardRedemption {
  id          String   @id @default(cuid())
  rewardId    String
  userId      String
  code        String   @unique @default(cuid())
  redeemedAt  DateTime @default(now())
  fulfilledAt DateTime?

  reward Reward @relation(fields: [rewardId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([rewardId])
}
