# ---------------------------------------------------------------
# Postgres (required) — used by Prisma
# ---------------------------------------------------------------
# Local:    postgresql://user:password@localhost:5432/soe_engage
# Supabase: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
# Neon:     postgresql://<user>:<pwd>@<host>.neon.tech/<db>?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# ---------------------------------------------------------------
# NextAuth
# ---------------------------------------------------------------
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-long-random-string"

# Optional — Google OAuth (keeps existing provider working)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---------------------------------------------------------------
# Legacy Supabase read-only fallback (optional, safe to leave blank)
# ---------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""